# Groq API Configuration
# Get your API key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Backend Server Configuration (Optional)
# Defaults to 8000 if not specified
NODE_ENV=development
PORT=8000

# Frontend Configuration (Optional)
# Used in vite.config.js if needed
VITE_API_BASE_URL=http://localhost:8000

# Playwright Configuration (Optional)
# Set to true for headless browser automation (production)
# Set to false for visible browser (development/debugging)
PLAYWRIGHT_HEADLESS=true
